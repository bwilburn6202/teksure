# Netlify cache headers
# Hashed assets (JS/CSS/images produced by Vite) — cache forever, they get new names on change
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons and manifest — cache for a week
/favicon.ico
  Cache-Control: public, max-age=604800
/favicon-192.png
  Cache-Control: public, max-age=604800
/favicon-512.png
  Cache-Control: public, max-age=604800
/manifest.json
  Cache-Control: public, max-age=604800

# Service worker — must always be fresh so updates are picked up immediately
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML — revalidate every time (short cache, SPA routes)
/*
  Cache-Control: public, max-age=0, must-revalidate
